# ── Authentification Claude ────────────────────────────
# Laisser vide si tu utilises OAuth (cdev auth)
ANTHROPIC_API_KEY=

# ── PostgreSQL ─────────────────────────────────────────
POSTGRES_USER=user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mydb

# ── Repos Git des projets ──────────────────────────────
# HTTPS public  : https://github.com/toi/mon-repo.git
# SSH privé     : git@github.com:toi/mon-repo.git
PROJECT_A_REPO=
PROJECT_A_BRANCH=main

PROJECT_B_REPO=
PROJECT_B_BRANCH=main

# ── SSH (pour repos privés) ────────────────────────────
# Chemin vers ta clé SSH locale (montée en lecture seule)
SSH_KEY_PATH=~/.ssh
